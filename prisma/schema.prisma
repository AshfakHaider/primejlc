generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  COUNSELOR
  TEACHER
  ACCOUNTANT
  STAFF
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?
  passwordHash String
  role         UserRole @default(STAFF)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedStudents Student[] @relation("AssignedCounselor")
  taughtBatches    CourseBatch[]
  payments         Payment[]     @relation("PaymentReceivedBy")
  expenses         Expense[]     @relation("ExpenseRecordedBy")
}

model Lead {
  id               String   @id @default(cuid())
  name             String
  city             String?
  phoneNumber      String
  whatsappNumber   String?
  facebookProfile  String?
  interestedIn     String
  status           String   @default("NEW")
  nextFollowUpDate DateTime?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status, nextFollowUpDate])
  @@index([interestedIn])
  @@index([city])
}

model Student {
  id                String            @id @default(cuid())
  studentId         String            @unique
  fullName          String
  phone             String
  email             String?
  address           String
  passportNumber    String?
  educationLevel    String
  programTrack      String            @default("LANGUAGE_AND_VISA")
  japaneseLevel     String
  targetIntake      String
  preferredCity     String
  assignedCounselorId String?
  applicationStatus String            @default("LEAD")
  coeStatus         String            @default("NOT_APPLIED")
  visaStatus        String            @default("NOT_APPLIED")
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  assignedCounselor User?             @relation("AssignedCounselor", fields: [assignedCounselorId], references: [id])
  admission         Admission?
  documents         DocumentChecklist?
  enrollments       Enrollment[]
  attendance        Attendance[]
  payments          Payment[]
}

model CourseBatch {
  id                String            @id @default(cuid())
  name              String
  teacherId         String?
  teacherName       String
  classSchedule     String
  programTrack      String            @default("LANGUAGE_PROGRAM")
  targetLevel       String            @default("N5")
  syllabusName      String            @default("JLPT/NAT Preparation")
  totalLessons      Int               @default(48)
  completedLessons  Int               @default(0)
  feeStatus         String            @default("UNPAID")
  preparationStatus String            @default("NOT_STARTED")
  batchStatus       String            @default("PLANNED")
  startDate         DateTime?
  endDate           DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  teacher     User?         @relation(fields: [teacherId], references: [id])
  enrollments Enrollment[]
  attendance  Attendance[]
  sessions    CourseSession[]
}

model Enrollment {
  id        String      @id @default(cuid())
  studentId String
  batchId   String
  joinedAt  DateTime    @default(now())
  feeStatus String      @default("UNPAID")
  progressPercent Int   @default(0)
  notes     String?

  student Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  batch   CourseBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([studentId, batchId])
}

model Attendance {
  id        String   @id @default(cuid())
  batchId   String
  sessionId String?
  studentId String
  date      DateTime
  present   Boolean  @default(false)
  note      String?

  batch   CourseBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  session CourseSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model CourseSession {
  id              String   @id @default(cuid())
  batchId         String
  lessonNo        Int
  title           String
  classDate       DateTime
  status          String   @default("COMPLETED")
  homework        String?
  teacherNote     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  batch      CourseBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  attendance Attendance[]
}

model Admission {
  id              String            @id @default(cuid())
  studentId       String            @unique
  currentStage    String            @default("LEAD")
  interviewDate   DateTime?
  coeAppliedAt    DateTime?
  coeIssuedAt     DateTime?
  visaAppliedAt   DateTime?
  visaApprovedAt  DateTime?
  flightDate      DateTime?
  notes           String?
  updatedAt       DateTime          @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model DocumentChecklist {
  id                   String   @id @default(cuid())
  studentId            String   @unique
  passport             Boolean  @default(false)
  photo                Boolean  @default(false)
  academicCertificates Boolean  @default(false)
  transcript           Boolean  @default(false)
  bankSolvency         Boolean  @default(false)
  bankStatement        Boolean  @default(false)
  sponsorDocuments     Boolean  @default(false)
  japaneseCertificate  Boolean  @default(false)
  applicationForm      Boolean  @default(false)
  sop                  Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  files   DocumentFile[]
}

model DocumentFile {
  id          String   @id @default(cuid())
  checklistId String
  fileName    String
  fileUrl     String
  fileType    String?
  uploadedAt  DateTime @default(now())

  checklist DocumentChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model School {
  id                  String        @id @default(cuid())
  name                String
  cityPrefecture      String
  intakeAvailability  String[]
  tuitionFee          Decimal       @db.Decimal(12, 2)
  applicationDeadline DateTime
  contactEmail        String
  partnerStatus       String        @default("PROSPECT")
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
}

model Payment {
  id             String   @id @default(cuid())
  receiptNo      String   @unique
  studentId      String
  admissionFee   Decimal  @default(0) @db.Decimal(12, 2)
  courseFee      Decimal  @default(0) @db.Decimal(12, 2)
  serviceCharge  Decimal  @default(0) @db.Decimal(12, 2)
  paidAmount     Decimal  @default(0) @db.Decimal(12, 2)
  dueAmount      Decimal  @default(0) @db.Decimal(12, 2)
  paymentDate    DateTime @default(now())
  method         String   @default("Cash")
  note           String?
  receivedById   String?
  createdAt      DateTime @default(now())

  student    Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  receivedBy User?   @relation("PaymentReceivedBy", fields: [receivedById], references: [id])
}

model Expense {
  id           String          @id @default(cuid())
  category     String
  title        String
  amount       Decimal         @db.Decimal(12, 2)
  expenseDate  DateTime        @default(now())
  vendor       String?
  note         String?
  recordedById String?
  createdAt    DateTime        @default(now())

  recordedBy User? @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
}

model AgencySetting {
  id        String   @id @default(cuid())
  name      String
  mobile    String
  email     String
  address   String
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CrmOption {
  id        String   @id @default(cuid())
  group     String
  value     String
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([group, value])
  @@index([group, isActive, sortOrder])
}
